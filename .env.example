# ─────────────────────────────────────────────────────────────────────────
# Forcepoint Intelligence Platform (FIP) — server-side configuration.
#
# Copy this file to /etc/ai-portal/api.env (production) or .env (local dev).
# NEVER commit real values. All variables are server-side only.
# ─────────────────────────────────────────────────────────────────────────

# ── Network ────────────────────────────────────────────────────────────
PORT=3000
HOST=127.0.0.1
# External base URL the server is reached on (no trailing slash).
# Used to derive SAML ACS URL and SP Entity ID.
PORTAL_BASE_URL=http://YOUR_SERVER_IP

# ── Session ────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ── Okta SAML 2.0 SSO ──────────────────────────────────────────────────
# Values from the Okta SAML app (Identity Provider metadata):
SAML_IDP_SSO_URL=https://YOUR_OKTA_DOMAIN/app/YOUR_APP_ID/sso/saml
SAML_IDP_ENTITY_ID=http://www.okta.com/YOUR_APP_ID
# Path to the IdP X.509 PEM certificate (preferred over inline SAML_IDP_CERT).
SAML_IDP_CERT_FILE=/etc/ai-portal/saml-idp.pem

# SP-side values — must match what is registered on the Okta app:
#   Single sign-on URL  →  SAML_SP_ACS_URL
#   Audience URI        →  SAML_SP_ENTITY_ID
SAML_SP_ACS_URL=http://YOUR_SERVER_IP/auth/saml/acs
SAML_SP_ENTITY_ID=http://YOUR_SERVER_IP/iris

# Dev impersonation — only active when FIP_ALLOW_DEV_LOGIN=1.
# Leave FIP_ALLOW_DEV_LOGIN unset or blank in production.
FIP_DEV_USER_NAME=Forcepoint Pilot User
FIP_DEV_USER_EMAIL=user@forcepoint.com
# FIP_ALLOW_DEV_LOGIN=1

# ── GitHub hopper ──────────────────────────────────────────────────────
# Service-account PAT with repo scope on the target repository.
# Never exposed to the browser.
GITHUB_HOPPER_TOKEN=
GITHUB_HOST=https://YOUR_GITHUB_ENTERPRISE_HOST
GITHUB_API=https://YOUR_GITHUB_ENTERPRISE_HOST/api/v3
GITHUB_OWNER=YOUR_ORG
GITHUB_REPO=YOUR_SKILLS_REPO
GITHUB_TRIAGE_BRANCH=main
GITHUB_TRIAGE_PATH=triage/incoming

# ── Ask AI proxy (/api/ask) ────────────────────────────────────────────
# Forwards to the Ask AI service (/ask endpoint).
ASK_BACKEND_URL=http://127.0.0.1:8100/ask
ASK_SERVICE_TOKEN=
ASK_TIMEOUT_MS=60000
ALLOWED_ORIGINS=http://YOUR_SERVER_IP
