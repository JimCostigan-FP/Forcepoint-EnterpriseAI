# ─────────────────────────────────────────────────────────────────────────
# Iris portal — server-side configuration.
#
# Target host: Forcepoint internal Linux server at 10.23.80.28
# (Benson owns DNS, Chris Brett owns VPN/ZTNA routing if it's touched.)
#
# Everything below is server-side. Nothing in this file is exposed to the
# browser bundle — no VITE_* prefixes.
# ─────────────────────────────────────────────────────────────────────────

# ── Network ────────────────────────────────────────────────────────────
PORT=3000
HOST=127.0.0.1
# Externally-visible base URL the portal is reached on. Used to build the
# SAML ACS URL and SP entity ID. When TLS is terminated upstream (nginx /
# ZTNA), update to https:// — `trust proxy` is already enabled in server.
PORTAL_BASE_URL=http://10.23.80.28

# ── Session ────────────────────────────────────────────────────────────
# Long random string. Required in production so logins survive a restart.
SESSION_SECRET=

# ── Okta SAML 2.0 SSO (AI-476 / AI-468) ────────────────────────────────
# Talton Walker provides the IdP-side values from the Okta SAML app:
#   - Identity Provider Single Sign-On URL → SAML_IDP_SSO_URL
#   - Identity Provider Issuer             → SAML_IDP_ENTITY_ID
#   - X.509 Certificate (PEM)              → SAML_IDP_CERT
SAML_IDP_SSO_URL=https://fp.okta.com/app/fp_forcepointenterpriseaiportalpending_1/exk23lnhuwbxNQ8YI1d8/sso/saml
SAML_IDP_ENTITY_ID=http://www.okta.com/exk23lnhuwbxNQ8YI1d8
# Preferred: write the PEM to a file the systemd service can read, then
# point at it here. systemd's EnvironmentFile strips backslashes from
# unquoted values, so embedding the PEM inline with literal \n separators
# corrupts the cert (every \n becomes just `n`).
SAML_IDP_CERT_FILE=/etc/ai-portal/saml-idp.pem
# Inline alternative (only if SAML_IDP_CERT_FILE is unset). Acceptable
# forms: real newlines (env value quoted in api.env), or a base64-encoded
# PEM string.
# SAML_IDP_CERT=

# SP-side values we publish back to Okta (these must match what Talton
# configures on the Okta app: Single sign-on URL + Audience URI).
SAML_SP_ACS_URL=http://10.23.80.28/auth/saml/acs
SAML_SP_ENTITY_ID=http://10.23.80.28/iris

# Dev impersonation (used when SAML_IDP_CERT is blank, or when
# IRIS_ALLOW_DEV_LOGIN=1 is set explicitly — handy for QA on the box).
IRIS_DEV_USER_NAME=Forcepoint Pilot User
IRIS_DEV_USER_EMAIL=pilot.user@forcepoint.com
# IRIS_ALLOW_DEV_LOGIN=1

# ── GitHub hopper (Iris MVP zip target — AI-471 / AI-453) ──────────────
# Service-account PAT, never exposed to the browser. Requires `repo` scope
# on the target repository.
GITHUB_HOPPER_TOKEN=
GITHUB_HOST=https://github.cicd.cloud.fpdev.io
GITHUB_API=https://github.cicd.cloud.fpdev.io/api/v3
GITHUB_OWNER=BTS
GITHUB_REPO=EAI-claude-skills
GITHUB_TRIAGE_BRANCH=main
GITHUB_TRIAGE_PATH=triage/incoming

# ── Anthropic proxy (existing /api/ask) ────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ALLOWED_ORIGINS=http://10.23.80.28
