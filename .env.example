# Personal access token used by SkillSubmit to create branches / PRs.
# Scope: `repo` on the target skills repo. The portal must point at the same
# GitHub host the PAT was issued on.
VITE_GITHUB_PAT=your-github-pat

# Optional overrides — defaults target Forcepoint GHE (BTS/EAI-claude-skills).
# Uncomment and set when running against a different host or fork.
# VITE_GITHUB_HOST=https://github.cicd.cloud.fpdev.io
# VITE_GITHUB_API=https://github.cicd.cloud.fpdev.io/api/v3
# VITE_GITHUB_OWNER=BTS
# VITE_GITHUB_REPO=EAI-claude-skills
