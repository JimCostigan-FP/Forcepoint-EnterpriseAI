# Set on the local-dev branch to skip the SSO LoginPage and render as the
# identity defined in src/lib/identity.js. Lets you run `npm run dev` alone
# without standing up the Node API server.
#
# Copy this file to .env.local (gitignored) and set the value below.
# Do NOT commit a real .env.local — it stays branch-local.
VITE_AUTH_BYPASS=true
